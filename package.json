{
  "name": "@inon-ai/okf-anything",
  "version": "0.1.7",
  "description": "okf-anything — escape Notion / Lark, sync into a local OKF Markdown knowledge base. CLI for humans & Claude Code.",
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "okfa": "bin/okfa"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "templates",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node bin/build-helper.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build && pnpm run typecheck",

    "dev": "tsc -p tsconfig.json --watch",
    "dev:build": "pnpm run build",
    "dev:run": "node bin/okfe-dev",
    "dev:link": "node bin/dev-link.mjs",
    "dev:unlink": "node bin/dev-unlink.mjs",
    "test": "pnpm run build && node --test tests/"
  },
  "keywords": [
    "okf-anything",
    "okf",
    "notion",
    "lark",
    "sync",
    "knowledge-base",
    "markdown",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacksonHe04/okf-anything.git"
  },
  "homepage": "https://github.com/JacksonHe04/okf-anything#readme",
  "bugs": {
    "url": "https://github.com/JacksonHe04/okf-anything/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@notionhq/client": "^5.22.0",
    "ignore": "^6.0.2",
    "p-queue": "^8.0.1",
    "yaml": "^2.6.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "6.0.3"
  }
}