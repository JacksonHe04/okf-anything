{
  "name": "@mookf/cli",
  "version": "0.1.0",
  "description": "mookf — escape Notion / Lark, sync into a local OKF Markdown knowledge base. CLI for humans & Claude Code.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mookf": "./bin/mookf"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-bin.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/cli.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mookf",
    "okf",
    "notion",
    "lark",
    "sync",
    "knowledge-base",
    "markdown",
    "claude-code"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@notionhq/client": "^5.22.0",
    "ignore": "^6.0.2",
    "p-queue": "^8.0.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.0"
  }
}
